---
import Layout from "@/layouts/Layout.astro";
import HorizontalGallery from "@/components/HorizontalGallery";
import { backstageBrands } from "@/data/backstage";

export function getStaticPaths() {
  return backstageBrands.map((b) => ({
    params: { brand: b.slug },
    props: { brand: b },
  }));
}

const { brand } = Astro.props;
---

<Layout title={`${brand.name} Backstage — Estelle Sweeney`}>
  <div class="min-h-screen bg-black text-white font-sans">

    <nav class="flex items-center justify-between px-6 py-5 border-b border-white/10 absolute top-0 left-0 right-0 z-10">
      <a href="/backstage" class="text-sm font-semibold tracking-[0.2em] uppercase font-display hover:opacity-50 transition-opacity">
        ← Backstage
      </a>
      <span class="text-xs tracking-[0.25em] uppercase font-display">{brand.name}</span>
    </nav>

    {brand.images.length > 0 ? (
      <HorizontalGallery images={brand.images} alt={`${brand.name} backstage`} client:load />
    ) : (
      <div class="flex items-center justify-center min-h-screen">
        <p class="text-white/30 text-xs tracking-[0.2em] uppercase font-display">Coming soon</p>
      </div>
    )}

  </div>
</Layout>
