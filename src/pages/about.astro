---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="About — Estelle Sweeney" description="Estelle Sweeney is a New York-based photographer, artist, and art director working across runway, backstage, editorial, and fine art.">
  <div class="min-h-screen bg-black text-cream">

    <nav class="flex items-center justify-between px-8 py-6 border-b border-white/10">
      <a href="/" class="text-sm font-semibold tracking-[0.2em] uppercase font-display hover:opacity-50 transition-opacity">Estelle Sweeney</a>
      <a href="mailto:estellescreative@gmail.com" class="text-xs tracking-[0.15em] uppercase font-display hover:opacity-50 transition-opacity">Contact</a>
    </nav>

    <main class="px-8 py-14 max-w-3xl mx-auto">

      {/* Header */}
      <h1 class="font-display text-sm tracking-[0.3em] uppercase pb-8 border-b border-white/10 mb-12">About</h1>

      {/* Intro */}
      <div class="flex flex-col gap-7 mb-16" style="font-family: Arial, sans-serif;">
        <p class="text-base leading-loose text-white/90">
          Estelle Sweeney is a New York-based photographer, artist, and art director working at the intersection of fashion and fine art.
          Her practice centers on 35mm analog film — a deliberate choice that shapes everything: the grain, the intimacy, the sense that something real happened in front of the lens.
        </p>
        <p class="text-base leading-loose text-white/75">
          She shoots runway, backstage, editorial, and campaign — with clients including KidSuper, Comme des Garçons, BAPE, Puma, and Billionaire Boys Club.
        </p>
      </div>

      {/* Practice areas */}
      <div class="mb-16 border-t border-white/10 pt-10">
        <h2 class="text-sm tracking-[0.25em] uppercase font-display text-white/40 mb-8">Practice</h2>
        <ul class="flex flex-col divide-y divide-white/10" style="font-family: Arial, sans-serif;">
          <li class="py-4 flex items-baseline justify-between">
            <span class="text-base">Runway &amp; Backstage</span>
            <span class="text-sm text-white/40 uppercase tracking-wider">NYFW · PFW</span>
          </li>
          <li class="py-4 flex items-baseline justify-between">
            <span class="text-base">Editorial &amp; Campaign</span>
            <span class="text-sm text-white/40 uppercase tracking-wider">Analog + Digital</span>
          </li>
          <li class="py-4 flex items-baseline justify-between">
            <span class="text-base">Fine Art &amp; Installation</span>
            <span class="text-sm text-white/40 uppercase tracking-wider">Mixed Media</span>
          </li>
          <li class="py-4 flex items-baseline justify-between">
            <span class="text-base">Graphic Design</span>
            <span class="text-sm text-white/40 uppercase tracking-wider">Art Direction</span>
          </li>
          <li class="py-4 flex items-baseline justify-between">
            <span class="text-base">Pame Studio</span>
            <span class="text-sm text-white/40 uppercase tracking-wider">Jewelry</span>
          </li>
        </ul>
      </div>

      {/* Approach */}
      <div class="mb-16 border-t border-white/10 pt-10">
        <h2 class="text-sm tracking-[0.25em] uppercase font-display text-white/40 mb-8">Approach</h2>
        <p class="text-base leading-loose text-white/75" style="font-family: Arial, sans-serif;">
          Shot on Portra 400, Portra 800, and Ilford — with a Canon R6 alongside for situations that won't wait.
          The work is cinematic and archival by instinct: raw access, imperfect moments, images that look like they've always existed.
          Fashion and fine art don't live in separate rooms here. They're the same practice.
        </p>
      </div>

      {/* Contact CTA */}
      <div class="border-t border-white/10 pt-10 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-24">
        <div class="flex flex-col gap-2">
          <span class="text-sm tracking-[0.25em] uppercase font-display text-white/40">Available for</span>
          <span class="text-base tracking-wider uppercase" style="font-family: Arial, sans-serif;">Runway · Backstage · Editorial · Campaign</span>
        </div>
        <a
          href="mailto:estellescreative@gmail.com"
          class="text-sm tracking-[0.2em] uppercase font-display underline underline-offset-4 hover:opacity-50 transition-opacity"
        >
          estellescreative@gmail.com
        </a>
      </div>

      {/* ── RÉSUMÉ ────────────────────────────────────────────── */}
      <div class="border-t-2 border-white/20 pt-14">
        <h2 class="font-display text-sm tracking-[0.3em] uppercase text-white/30 mb-14">Résumé</h2>

        {/* Selected Shows */}
        <div class="mb-14">
          <h3 class="text-sm tracking-[0.25em] uppercase font-display text-white mb-8 pb-4 border-b border-white/10">Selected Shows</h3>
          <ul class="flex flex-col divide-y divide-white/10" style="font-family: Arial, sans-serif;">
            <li class="py-4 flex items-baseline justify-between">
              <span class="text-base">Walter Van Bierendonck</span>
              <span class="text-sm text-white/40 ml-4 shrink-0">PFW 2026</span>
            </li>
            <li class="py-4 flex items-baseline justify-between">
              <span class="text-base">KidSuper AW26/27</span>
              <span class="text-sm text-white/40 ml-4 shrink-0">PFW 2026</span>
            </li>
            <li class="py-4 flex items-baseline justify-between">
              <span class="text-base">Vivienne Westwood AW25</span>
              <span class="text-sm text-white/40 ml-4 shrink-0">PFW 2025</span>
            </li>
            <li class="py-4 flex items-baseline justify-between">
              <span class="text-base">Mugler AW25</span>
              <span class="text-sm text-white/40 ml-4 shrink-0">PFW 2025</span>
            </li>
            <li class="py-4 flex items-baseline justify-between">
              <span class="text-base">Franck Sorbier — Couture</span>
              <span class="text-sm text-white/40 ml-4 shrink-0">PFW 2024</span>
            </li>
            <li class="py-4 flex items-baseline justify-between">
              <span class="text-base">Rick Owens SS24</span>
              <span class="text-sm text-white/40 ml-4 shrink-0">PFW 2024</span>
            </li>
            <li class="py-4 flex items-baseline justify-between">
              <span class="text-base">Mugler SS24</span>
              <span class="text-sm text-white/40 ml-4 shrink-0">PFW 2024</span>
            </li>
            <li class="py-4 flex items-baseline justify-between">
              <span class="text-base">3.Paradis SS25</span>
              <span class="text-sm text-white/40 ml-4 shrink-0">PFW 2025</span>
            </li>
            <li class="py-4 flex items-baseline justify-between">
              <span class="text-base">Yuima Nakazato</span>
              <span class="text-sm text-white/40 ml-4 shrink-0">PFW 2026</span>
            </li>
            <li class="py-4 flex items-baseline justify-between">
              <span class="text-base">Grace Ling AW26</span>
              <span class="text-sm text-white/40 ml-4 shrink-0">NYFW 2026</span>
            </li>
            <li class="py-4 flex items-baseline justify-between">
              <span class="text-base">Tombogo AW25</span>
              <span class="text-sm text-white/40 ml-4 shrink-0">NYFW 2025</span>
            </li>
            <li class="py-4 flex items-baseline justify-between">
              <span class="text-base">Rhude AW24</span>
              <span class="text-sm text-white/40 ml-4 shrink-0">NYFW 2024</span>
            </li>
          </ul>
        </div>

        {/* Selected Clients */}
        <div class="mb-14">
          <h3 class="text-sm tracking-[0.25em] uppercase font-display text-white mb-8 pb-4 border-b border-white/10">Selected Clients</h3>
          <ul class="flex flex-col divide-y divide-white/10" style="font-family: Arial, sans-serif;">
            <li class="py-4 text-base">KidSuper</li>
            <li class="py-4 text-base">Comme des Garçons</li>
            <li class="py-4 text-base">BAPE</li>
            <li class="py-4 text-base">Puma</li>
            <li class="py-4 text-base">Billionaire Boys Club</li>
          </ul>
        </div>

        {/* Expertise */}
        <div class="mb-14">
          <h3 class="text-sm tracking-[0.25em] uppercase font-display text-white mb-8 pb-4 border-b border-white/10">Expertise</h3>
          <ul class="flex flex-col divide-y divide-white/10" style="font-family: Arial, sans-serif;">
            <li class="py-4 flex items-baseline justify-between gap-4">
              <span class="text-base">35mm Analog Photography</span>
              <span class="text-sm text-white/40 shrink-0">Portra 400 · Portra 800 · Ilford</span>
            </li>
            <li class="py-4 flex items-baseline justify-between gap-4">
              <span class="text-base">Medium Format</span>
              <span class="text-sm text-white/40 shrink-0">Mamiya</span>
            </li>
            <li class="py-4 flex items-baseline justify-between gap-4">
              <span class="text-base">Digital Photography</span>
              <span class="text-sm text-white/40 shrink-0">Canon R6</span>
            </li>
            <li class="py-4 flex items-baseline justify-between gap-4">
              <span class="text-base">Studio Lighting</span>
              <span class="text-sm text-white/40 shrink-0">Profoto · Godox</span>
            </li>
            <li class="py-4 flex items-baseline justify-between gap-4">
              <span class="text-base">Post-Production</span>
              <span class="text-sm text-white/40 shrink-0">Lightroom · Capture One · Photoshop</span>
            </li>
            <li class="py-4 flex items-baseline justify-between gap-4">
              <span class="text-base">Art Direction</span>
              <span class="text-sm text-white/40 shrink-0">Concept · Creative</span>
            </li>
            <li class="py-4 flex items-baseline justify-between gap-4">
              <span class="text-base">Jewelry Design</span>
              <span class="text-sm text-white/40 shrink-0">Lost Wax Casting · Silver Fabrication</span>
            </li>
          </ul>
        </div>

        {/* Based + Social */}
        <div class="border-t border-white/10 pt-10 pb-16 flex items-end justify-between" style="font-family: Arial, sans-serif;">
          <div class="flex flex-col gap-2">
            <span class="text-sm tracking-[0.25em] uppercase font-display text-white/30">Based</span>
            <span class="text-base text-white/70">New York City</span>
          </div>
          <a
            href="https://www.instagram.com/estellesweeney_"
            target="_blank"
            rel="noopener noreferrer"
            class="opacity-50 hover:opacity-100 transition-opacity"
            aria-label="Instagram"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="white">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        </div>

      </div>

    </main>
  </div>
</Layout>
