---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="About — Estelle Sweeney" description="Estelle Sweeney is a New York-based photographer, artist, and art director working across runway, backstage, editorial, and fine art.">
  <div class="min-h-screen bg-black text-cream">

    <nav class="flex items-center justify-between px-6 py-5 border-b border-white/10">
      <a href="/" class="text-sm font-semibold tracking-[0.2em] uppercase font-display hover:opacity-50 transition-opacity">Estelle Sweeney</a>
      <a href="mailto:estellescreative@gmail.com" class="text-xs tracking-[0.15em] uppercase font-display hover:opacity-50 transition-opacity">Contact</a>
    </nav>

    <main class="px-6 py-10 max-w-2xl">

      {/* Header */}
      <h1 class="font-display text-xs tracking-[0.25em] uppercase pb-6 border-b border-white/10 mb-10">About</h1>

      {/* Intro */}
      <div class="flex flex-col gap-6 mb-14" style="font-family: Arial, sans-serif;">
        <p class="text-sm leading-relaxed text-white/90">
          Estelle Sweeney is a New York-based photographer, artist, and art director working at the intersection of fashion and fine art.
          Her practice centers on 35mm analog film — a deliberate choice that shapes everything: the grain, the intimacy, the sense that something real happened in front of the lens.
        </p>
        <p class="text-sm leading-relaxed text-white/80">
          She shoots runway, backstage, editorial, and campaign — with clients including KidSuper, Comme des Garçons, BAPE, Puma, and Billionaire Boys Club.
        </p>
      </div>

      {/* Practice areas */}
      <div class="mb-14 border-t border-white/10 pt-8">
        <h2 class="text-xs tracking-[0.25em] uppercase font-display text-white/40 mb-6">Practice</h2>
        <ul class="flex flex-col gap-0 divide-y divide-white/10" style="font-family: Arial, sans-serif;">
          <li class="py-3 flex items-baseline justify-between">
            <span class="text-sm">Runway &amp; Backstage</span>
            <span class="text-xs text-white/40 uppercase tracking-wider">NYFW · PFW</span>
          </li>
          <li class="py-3 flex items-baseline justify-between">
            <span class="text-sm">Editorial &amp; Campaign</span>
            <span class="text-xs text-white/40 uppercase tracking-wider">Analog + Digital</span>
          </li>
          <li class="py-3 flex items-baseline justify-between">
            <span class="text-sm">Fine Art &amp; Installation</span>
            <span class="text-xs text-white/40 uppercase tracking-wider">Mixed Media</span>
          </li>
          <li class="py-3 flex items-baseline justify-between">
            <span class="text-sm">Graphic Design</span>
            <span class="text-xs text-white/40 uppercase tracking-wider">Art Direction</span>
          </li>
          <li class="py-3 flex items-baseline justify-between">
            <span class="text-sm">Pame Studio</span>
            <span class="text-xs text-white/40 uppercase tracking-wider">Jewelry</span>
          </li>
        </ul>
      </div>

      {/* Signature style */}
      <div class="mb-14 border-t border-white/10 pt-8">
        <h2 class="text-xs tracking-[0.25em] uppercase font-display text-white/40 mb-6">Approach</h2>
        <p class="text-sm leading-relaxed text-white/80" style="font-family: Arial, sans-serif;">
          Shot on Portra 400, Portra 800, and Ilford — with a Canon R6 alongside for situations that won't wait.
          The work is cinematic and archival by instinct: raw access, imperfect moments, images that look like they've always existed.
          Fashion and fine art don't live in separate rooms here. They're the same practice.
        </p>
      </div>

      {/* Contact CTA */}
      <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-24">
        <div class="flex flex-col gap-1">
          <span class="text-xs tracking-[0.25em] uppercase font-display text-white/40">Available for</span>
          <span class="text-sm tracking-wider uppercase" style="font-family: Arial, sans-serif;">Runway · Backstage · Editorial · Campaign</span>
        </div>
        <a
          href="mailto:estellescreative@gmail.com"
          class="text-xs tracking-[0.2em] uppercase font-display underline underline-offset-4 hover:opacity-50 transition-opacity"
        >
          estellescreative@gmail.com
        </a>
      </div>

      {/* ── RÉSUMÉ ────────────────────────────────────────────── */}
      <div class="border-t-2 border-white/20 pt-12">
        <h2 class="font-display text-xs tracking-[0.3em] uppercase text-white/30 mb-12">Résumé</h2>

        {/* Selected Shows */}
        <div class="mb-12">
          <h3 class="text-xs tracking-[0.25em] uppercase font-display text-white mb-6 pb-3 border-b border-white/10">Selected Shows</h3>
          <ul class="flex flex-col divide-y divide-white/10" style="font-family: Arial, sans-serif;">
            <li class="py-2.5 flex items-baseline justify-between">
              <span class="text-sm">Walter Van Bierendonck</span>
              <span class="text-xs text-white/40 ml-4 shrink-0">PFW 2026</span>
            </li>
            <li class="py-2.5 flex items-baseline justify-between">
              <span class="text-sm">KidSuper AW26/27</span>
              <span class="text-xs text-white/40 ml-4 shrink-0">PFW 2026</span>
            </li>
            <li class="py-2.5 flex items-baseline justify-between">
              <span class="text-sm">Vivienne Westwood AW25</span>
              <span class="text-xs text-white/40 ml-4 shrink-0">PFW 2025</span>
            </li>
            <li class="py-2.5 flex items-baseline justify-between">
              <span class="text-sm">Mugler AW25</span>
              <span class="text-xs text-white/40 ml-4 shrink-0">PFW 2025</span>
            </li>
            <li class="py-2.5 flex items-baseline justify-between">
              <span class="text-sm">Franck Sorbier — Couture</span>
              <span class="text-xs text-white/40 ml-4 shrink-0">PFW 2024</span>
            </li>
            <li class="py-2.5 flex items-baseline justify-between">
              <span class="text-sm">Rick Owens SS24</span>
              <span class="text-xs text-white/40 ml-4 shrink-0">PFW 2024</span>
            </li>
            <li class="py-2.5 flex items-baseline justify-between">
              <span class="text-sm">Mugler SS24</span>
              <span class="text-xs text-white/40 ml-4 shrink-0">PFW 2024</span>
            </li>
            <li class="py-2.5 flex items-baseline justify-between">
              <span class="text-sm">3.Paradis SS25</span>
              <span class="text-xs text-white/40 ml-4 shrink-0">PFW 2025</span>
            </li>
            <li class="py-2.5 flex items-baseline justify-between">
              <span class="text-sm">Yuima Nakazato</span>
              <span class="text-xs text-white/40 ml-4 shrink-0">PFW 2026</span>
            </li>
            <li class="py-2.5 flex items-baseline justify-between">
              <span class="text-sm">Grace Ling AW26</span>
              <span class="text-xs text-white/40 ml-4 shrink-0">NYFW 2026</span>
            </li>
            <li class="py-2.5 flex items-baseline justify-between">
              <span class="text-sm">Tombogo AW25</span>
              <span class="text-xs text-white/40 ml-4 shrink-0">NYFW 2025</span>
            </li>
            <li class="py-2.5 flex items-baseline justify-between">
              <span class="text-sm">Rhude AW24</span>
              <span class="text-xs text-white/40 ml-4 shrink-0">NYFW 2024</span>
            </li>
          </ul>
        </div>

        {/* Selected Clients */}
        <div class="mb-12">
          <h3 class="text-xs tracking-[0.25em] uppercase font-display text-white mb-6 pb-3 border-b border-white/10">Selected Clients</h3>
          <ul class="flex flex-col divide-y divide-white/10" style="font-family: Arial, sans-serif;">
            <li class="py-2.5 text-sm">KidSuper</li>
            <li class="py-2.5 text-sm">Comme des Garçons</li>
            <li class="py-2.5 text-sm">BAPE</li>
            <li class="py-2.5 text-sm">Puma</li>
            <li class="py-2.5 text-sm">Billionaire Boys Club</li>
          </ul>
        </div>

        {/* Expertise */}
        <div class="mb-12">
          <h3 class="text-xs tracking-[0.25em] uppercase font-display text-white mb-6 pb-3 border-b border-white/10">Expertise</h3>
          <ul class="flex flex-col divide-y divide-white/10" style="font-family: Arial, sans-serif;">
            <li class="py-2.5 flex items-baseline justify-between">
              <span class="text-sm">35mm Analog Photography</span>
              <span class="text-xs text-white/40">Portra 400 · Portra 800 · Ilford</span>
            </li>
            <li class="py-2.5 flex items-baseline justify-between">
              <span class="text-sm">Medium Format</span>
              <span class="text-xs text-white/40">Mamiya</span>
            </li>
            <li class="py-2.5 flex items-baseline justify-between">
              <span class="text-sm">Digital Photography</span>
              <span class="text-xs text-white/40">Canon R6</span>
            </li>
            <li class="py-2.5 flex items-baseline justify-between">
              <span class="text-sm">Studio Lighting</span>
              <span class="text-xs text-white/40">Profoto · Godox</span>
            </li>
            <li class="py-2.5 flex items-baseline justify-between">
              <span class="text-sm">Post-Production</span>
              <span class="text-xs text-white/40">Lightroom · Capture One · Photoshop</span>
            </li>
            <li class="py-2.5 flex items-baseline justify-between">
              <span class="text-sm">Art Direction</span>
              <span class="text-xs text-white/40">Concept · Creative</span>
            </li>
            <li class="py-2.5 flex items-baseline justify-between">
              <span class="text-sm">Jewelry Design</span>
              <span class="text-xs text-white/40">Lost Wax Casting · Silver Fabrication</span>
            </li>
          </ul>
        </div>

        {/* Based */}
        <div class="border-t border-white/10 pt-8 pb-16 flex flex-col gap-1" style="font-family: Arial, sans-serif;">
          <span class="text-xs tracking-[0.25em] uppercase font-display text-white/30">Based</span>
          <span class="text-sm text-white/70">New York City</span>
        </div>

      </div>

    </main>
  </div>
</Layout>
