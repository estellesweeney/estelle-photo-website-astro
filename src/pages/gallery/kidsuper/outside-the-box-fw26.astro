---
import Layout from "@/layouts/Layout.astro";
import GalleryLightbox from "@/components/GalleryLightbox";

const images = [
  "/slides/kidsuper/otb-01.jpg",
  "/slides/kidsuper/otb-02.jpg",
  "/slides/kidsuper/otb-03.jpg",
  "/slides/kidsuper/otb-04.jpg",
  "/slides/kidsuper/otb-05.jpg",
  "/slides/kidsuper/otb-06.jpg",
  "/slides/kidsuper/otb-07.jpg",
  "/slides/kidsuper/otb-08.jpg",
  "/slides/kidsuper/otb-09.jpg",
  "/slides/kidsuper/otb-10.jpg",
];
---

<Layout title='"Outside the Box" F/W 26 — KidSuper — Estelle Sweeney'>
  <div class="min-h-screen bg-black text-cream font-sans">

    <nav class="flex items-center justify-between px-6 py-5 border-b border-white/10">
      <a href="/" class="text-sm font-semibold tracking-[0.2em] uppercase font-display hover:opacity-50 transition-opacity">Estelle Sweeney</a>
      <a href="mailto:estellescreative@gmail.com" class="text-xs tracking-[0.15em] uppercase font-display hover:opacity-50 transition-opacity">Contact</a>
    </nav>

    <main class="py-10 ">
      <div class="flex items-baseline justify-between mb-8 border-b border-white/10 pb-4">
        <div class="flex items-baseline gap-3">
          <a href="/gallery/kidsuper" class="text-xs tracking-[0.15em] uppercase font-display text-white/40 hover:text-cream transition-colors">KidSuper</a>
          <span class="text-white/20">—</span>
          <h1 class="text-xs tracking-[0.25em] uppercase font-display font-semibold">"Outside the Box"</h1>
        </div>
        <span class="text-xs tracking-[0.15em] uppercase font-display text-white/40">F/W 26</span>
      </div>

      <GalleryLightbox images={images} alt='KidSuper "Outside the Box" F/W 26' client:load />
    </main>

  </div>
</Layout>
