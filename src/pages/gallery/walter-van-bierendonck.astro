---
import Layout from "@/layouts/Layout.astro";
import GalleryLightbox from "@/components/GalleryLightbox";

const images = [
  "/slides/walter-van-beirendonck.jpg",
  "/slides/wvb-1.jpg",
  "/slides/wvb-3.jpg",
];
---

<Layout title="Walter Van Bierendonck — Estelle Sweeney">
  <div class="min-h-screen bg-black text-cream font-sans">

    <nav class="flex items-center justify-between px-6 py-5 border-b border-white/10">
      <a href="/" class="text-sm font-semibold tracking-[0.2em] uppercase hover:opacity-50 transition-opacity">Estelle Sweeney</a>
      <a href="mailto:hello@estellesweeney.com" class="text-xs tracking-[0.15em] uppercase hover:opacity-50 transition-opacity">Contact</a>
    </nav>

    <main class="px-6 py-10 max-w-6xl mx-auto">
      <div class="flex items-baseline justify-between mb-8 border-b border-white/10 pb-4">
        <h1 class="text-xs tracking-[0.25em] uppercase font-semibold">Walter Van Bierendonck</h1>
        <span class="text-xs tracking-[0.15em] uppercase text-white/40">Runway</span>
      </div>

      <GalleryLightbox images={images} alt="Walter Van Bierendonck" client:load />
    </main>

  </div>
</Layout>
