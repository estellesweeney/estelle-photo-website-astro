---
import Layout from "@/layouts/Layout.astro";

const images = [
  "/slides/walter-van-beirendonck.jpg",
  "/slides/wvb-1.jpg",
  "/slides/wvb-3.jpg",
];
---

<Layout title="Walter Van Bierendonck — Estelle Sweeney">
  <main class="mx-auto w-full max-w-6xl px-6 py-10 md:py-16">
    <div class="mb-8 flex items-center gap-4">
      <a href="/" class="text-sm text-muted-foreground hover:text-foreground transition-colors">← Back</a>
      <h1 class="text-2xl font-semibold tracking-tight sm:text-3xl">Walter Van Bierendonck</h1>
    </div>
    <div class="columns-1 gap-4 sm:columns-2 lg:columns-3 space-y-4">
      {images.map((src) => (
        <div class="break-inside-avoid overflow-hidden rounded-xl">
          <img
            src={src}
            alt="Walter Van Bierendonck"
            class="w-full object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </main>
</Layout>
