---
import Layout from "@/layouts/Layout.astro";
import GalleryLightbox from "@/components/GalleryLightbox";

const images = [
  "/slides/bbc-hero.jpg",
];
---

<Layout title="Summer — Billionaire Boys Club — Estelle Sweeney">
  <div class="min-h-screen bg-black text-cream font-sans">

    <nav class="flex items-center justify-between px-6 py-5 border-b border-white/10">
      <a href="/" class="text-sm font-semibold tracking-[0.2em] uppercase font-display hover:opacity-50 transition-opacity">Estelle Sweeney</a>
      <a href="mailto:estellescreative@gmail.com" class="text-xs tracking-[0.15em] uppercase font-display hover:opacity-50 transition-opacity">Contact</a>
    </nav>

    <main class="py-10 ">
      <div class="flex items-baseline justify-between mb-8 border-b border-white/10 pb-4">
        <div class="flex items-baseline gap-3">
          <a href="/gallery/billionaire-boys-club" class="text-xs tracking-[0.15em] uppercase font-display text-white/40 hover:text-cream transition-colors">Billionaire Boys Club</a>
          <span class="text-white/20">—</span>
          <h1 class="text-xs tracking-[0.25em] uppercase font-display font-semibold">Summer</h1>
        </div>
        <span class="text-xs tracking-[0.15em] uppercase font-display text-white/40">Campaign</span>
      </div>

      <GalleryLightbox images={images} alt="Billionaire Boys Club Summer" client:load />
    </main>

  </div>
</Layout>
