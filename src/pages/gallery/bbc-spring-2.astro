---
import Layout from "@/layouts/Layout.astro";

const images = [
  "/slides/bbc-spring2.jpg",
  "/slides/bbc-spring2-b.jpg",
  "/slides/bbc-spring2-c.jpg",
  "/slides/bbc-01.jpg",
  "/slides/bbc-02.jpg",
  "/slides/bbc-03.jpg",
  "/slides/bbc-04.jpg",
  "/slides/bbc-05.jpg",
  "/slides/bbc-06.jpg",
  "/slides/bbc-07.jpg",
  "/slides/bbc-08.jpg",
  "/slides/bbc-09.jpg",
  "/slides/bbc-10.jpg",
  "/slides/bbc-11.jpg",
];
---

<Layout title="Billionaire Boys Club Spring 2 — Estelle Sweeney">
  <main class="mx-auto w-full max-w-6xl px-6 py-10 md:py-16">
    <div class="mb-8 flex items-center gap-4">
      <a href="/" class="text-sm text-muted-foreground hover:text-foreground transition-colors">← Back</a>
      <h1 class="text-2xl font-semibold tracking-tight sm:text-3xl">Billionaire Boys Club Spring 2</h1>
    </div>
    <div class="columns-1 gap-4 sm:columns-2 lg:columns-3 space-y-4">
      {images.map((src) => (
        <div class="break-inside-avoid overflow-hidden rounded-xl">
          <img
            src={src}
            alt="Billionaire Boys Club Spring 2"
            class="w-full object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </main>
</Layout>
